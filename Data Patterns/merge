#include <stdio.h>

void mergeHalves(int arr[], int n) {
    int mid = n / 2;
    int i = 0;
    int j = mid;

    while (i < mid && j < n) {
        if (arr[i] <= arr[j]) {
            i++;
        } else {
            int value = arr[j];
            int index = j;

            while (index > i) {
                arr[index] = arr[index - 1];
                index--;
            }
            arr[i] = value;

            i++;
            mid++;
            j++;
        }
    }
}

int main() {
    int arr[] = {2, 3, 8, -1, 7, 10};
    int n = sizeof(arr) / sizeof(arr[0]);

    mergeHalves(arr, n);

    for (int i = 0; i < n; i++) {
        printf("%d ", arr[i]);
    }
    printf("\n");

    return 0;
}
