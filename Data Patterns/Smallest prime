def is_prime(n):
    if n <= 1:
        return False
    if n <= 3:
        return True
    if n % 2 == 0 or n % 3 == 0:
        return False
    i = 5
    while i * i <= n:
        if n % i == 0 or n % (i + 2) == 0:
            return False
        i += 6
    return True

def next_prime(x):
    n = x + 1
    while True:
        if is_prime(n):
            return n
        n += 1

if __name__ == "__main__":
    user_input = int(input("Enter a number: "))
    print(next_prime(user_input))
