import sys

def solve():
    # Read all inputs from standard input
    input_data = sys.stdin.read().split()
    if not input_data:
        return
        
    t = int(input_data[0])
    
    # Process each test case
    for i in range(1, t + 1):
        n = int(input_data[i])
        
        result = []
        left = 1
        right = 2 * n
        
        # Alternately pick from the left side and right side
        for step in range(n):
            if step % 2 == 0:
                result.append(left)
                left += 1
            else:
                result.append(right)
                right -= 1
                
        # Print the resulting array elements separated by a space
        print(*(result))

if __name__ == '__main__':
    solve()
